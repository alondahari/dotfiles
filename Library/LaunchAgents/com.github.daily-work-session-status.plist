<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>com.github.daily-work-session-status</string>
	<key>ProgramArguments</key>
	<array>
		<string>/Users/alondahari/.nvm/nvm-exec</string>
		<string>node</string>
		<string>/Users/alondahari/.local/bin/daily-work-reconciler.cjs</string>
		<string>--watch-sessions</string>
	</array>
	<key>EnvironmentVariables</key>
	<dict>
		<key>HOME</key>
		<string>/Users/alondahari</string>
		<key>NVM_DIR</key>
		<string>/Users/alondahari/.nvm</string>
		<key>NODE_VERSION</key>
		<string>default</string>
	</dict>
	<key>RunAtLoad</key>
	<true/>
	<key>KeepAlive</key>
	<true/>
	<key>StandardOutPath</key>
	<string>/tmp/com.github.daily-work-session-status.log</string>
	<key>StandardErrorPath</key>
	<string>/tmp/com.github.daily-work-session-status.error.log</string>
</dict>
</plist>
